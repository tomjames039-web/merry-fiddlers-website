# ===========================================
# The Merry Fiddlers - Environment Variables
# ===========================================

# Stripe Configuration (for card payments / vouchers)
# Get your keys from https://dashboard.stripe.com/apikeys
# - SECRET key is used on the server to create checkout sessions.
# - PUBLISHABLE key (NEXT_PUBLIC_) is used in the browser for the on-site
#   embedded card form. BOTH are required for checkout to work.
# - WEBHOOK secret is optional but recommended (Developers > Webhooks,
#   endpoint: https://your-site/api/webhook, event checkout.session.completed).
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service - Resend (REQUIRED for production)
# Sign up at https://resend.com and get your API key
# Free tier: 100 emails/day, 3,000/month
#
# This enables:
#   - Afternoon tea voucher emails (automatically sent after payment)
#   - Brochure download emails (sent when someone downloads the brochure)
#   - Email notifications when leads come in
#   - Auto-reply emails to leads
#
# Setup instructions:
# 1. Go to https://resend.com and sign up
# 2. Verify your domain (or use their test domain for testing)
# 3. Get your API key from the dashboard
# 4. Add it here and in your Netlify environment variables
RESEND_API_KEY=re_your_api_key

# Admin Back Office
# Password for accessing the /admin back office (leads + vouchers).
# Set either ADMIN_PASSWORD or ADMIN_API_KEY. Default 'merryfiddlers2025'.
ADMIN_PASSWORD=merryfiddlers2025
ADMIN_API_KEY=merryfiddlers2025

# Where business notifications (new sales & enquiries) are sent.
# Defaults to info@themerryfiddlers.co.uk if not set.
BUSINESS_EMAIL=info@themerryfiddlers.co.uk

# Site URL (for webhook callbacks and emails)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# ===========================================
# Social Media Feed (on-page)
# ===========================================
# Facebook works out of the box (free Page Plugin, no key needed). Override the
# page only if the handle changes:
# NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/themerryfiddlerspub/
#
# Instagram LIVE feed. A LightWidget feed for @themerryfiddlers is already wired
# in as the built-in default (DEFAULT_INSTAGRAM_EMBED in components/SocialFeed.tsx),
# so Instagram is live with no config. Only set this variable if you want to
# OVERRIDE it with a different widget (LightWidget / SnapWidget / Behold) without
# editing code. See .same/SOCIAL-FEED-SETUP.md.
# NEXT_PUBLIC_INSTAGRAM_EMBED_URL=https://lightwidget.com/widgets/xxxxxxxx.html

# Google Analytics 4
# Get your Measurement ID from https://analytics.google.com
# Go to Admin > Data Streams > Your Stream > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# Database (Optional - for permanent storage)
# ===========================================

# Supabase (recommended)
# Sign up at https://supabase.com
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_KEY=your_service_key

# Or use PlanetScale, Neon, or any other database

# ===========================================
# Email Marketing (Optional)
# ===========================================

# Mailchimp
# MAILCHIMP_API_KEY=your_api_key
# MAILCHIMP_LIST_ID=your_list_id

# ConvertKit
# CONVERTKIT_API_KEY=your_api_key
# CONVERTKIT_FORM_ID=your_form_id
